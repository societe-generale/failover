### graphify knowledge graph ###
# Keep the token-preserving semantic cache + browsable artifacts; ignore the rest
# (regenerable for free, or machine-specific absolute paths).
graphify-out/*
!graphify-out/GRAPH_REPORT.md
!graphify-out/graph.html
!graphify-out/graph.json
!graphify-out/manifest.json
!graphify-out/cache/
graphify-out/cache/*
!graphify-out/cache/semantic/
!graphify-out/cache/stat-index.json
# regenerable / machine-specific (never track)
graphify-out/cache/ast/
graphify-out/.graphify_python
graphify-out/.graphify_root
graphify-out/.graphify_chunks.json
graphify-out/.graphify_labels.json
graphify-out/cost.json